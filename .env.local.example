# Database (PostgreSQL)
DATABASE_URL="add"

# Upstash Redis (Vercel KV)
UPSTASH_REDIS_REST_URL="add"
UPSTASH_REDIS_REST_TOKEN="add"

# NextAuth
NEXTAUTH_SECRET="add"
NEXTAUTH_URL="add"

# OAuth (Google) – optional
GOOGLE_CLIENT_ID="add"
GOOGLE_CLIENT_SECRET="add"

# Email Reports (Resend)
RESEND_API_KEY="add"

# Cron Security
CRON_SECRET="add"

# IP2Location.io API Keys (comma separated for rotation)
IP2LOCATION_API_KEYS="add"

# Redis cache TTL for geo (seconds)
IP2LOCATION_CACHE_TTL=3600

# Production URL (set in Vercel)
NEXTAUTH_URL="nexlink.vercel.app"