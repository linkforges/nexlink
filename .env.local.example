# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/nexgen"

# Upstash Redis (Vercel KV)
UPSTASH_REDIS_REST_URL="https://your-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-token"

# NextAuth
NEXTAUTH_SECRET="your-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# OAuth (Google) – optional
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Reports (Resend)
RESEND_API_KEY="your-resend-api-key"

# Cron Security
CRON_SECRET="your-cron-secret"

# IP2Location.io API Keys (comma separated for rotation)
IP2LOCATION_API_KEYS="0CE21DF81A3D778DE561051830772374,93504106942053D65B4D12A876539A8F"

# Redis cache TTL for geo (seconds)
IP2LOCATION_CACHE_TTL=3600

# Production URL (set in Vercel)
NEXTAUTH_URL="https://your-vercel-url.vercel.app"